# Telegram — t.me/BotFather para criar o bot e pegar o token
TELEGRAM_BOT_TOKEN=seu_token_aqui
# ID do canal: @seucanaldeals (público) ou -100xxxxxxxxxx (privado)
TELEGRAM_CHANNEL_ID=@seucanaldeals

# Groq (mesmo do pipeline)
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# Afiliados (mesmos do pipeline)
AMAZON_AFFILIATE_TAG=seunome-20
SHOPEE_AFFILIATE_ID=seu_id_aqui

# YouTube — link do canal para aparecer nas mensagens do Telegram (opcional)
# Ex: https://youtube.com/@seucanal
YOUTUBE_CHANNEL=

# Nicho: "tech", "sports" ou "both"
ACTIVE_NICHE=tech

# Horários de postagem separados por vírgula (formato 24h)
POST_HOURS=8,13,20
