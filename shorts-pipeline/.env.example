# LLM — troque para "groq" para melhor qualidade (recomendado)
LLM_PROVIDER=ollama
GROQ_API_KEY=sua_groq_key_aqui
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama local (usado se LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Imagens royalty-free — unsplash.com/developers
UNSPLASH_ACCESS_KEY=seu_unsplash_key_aqui

# Amazon Associates — associados.amazon.com.br
AMAZON_AFFILIATE_TAG=seunome-20

# Shopee Afiliados — affiliate.shopee.com.br
SHOPEE_AFFILIATE_ID=seu_id_shopee_aqui

# Kling AI — klingai.com/dev (66 créditos/dia grátis)
KLING_ACCESS_KEY=seu_access_key_aqui
KLING_SECRET_KEY=seu_secret_key_aqui

# Encoder FFmpeg: "auto" detecta GPU automaticamente (AMD AMF / NVENC / CPU)
VIDEO_ENCODER=auto

# YouTube auto-upload — coloque "true" após configurar client_secrets.json
YOUTUBE_AUTO_UPLOAD=false
YOUTUBE_CREDENTIALS_FILE=client_secrets.json
YOUTUBE_TOKEN_FILE=token.json
YOUTUBE_PRIVACY=private
